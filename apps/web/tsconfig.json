{
    "extends": "@repo/typescript-config/react-library",
    "compilerOptions": {
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ES2022",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["vite/client"],
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        },
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": ["src/**/*", "worker-configuration.d.ts", "vite.config.ts"],
    "exclude": ["node_modules", "app"]
}
